#!/bin/bash
# pre-push hook: AI_SYNC.md는 더 이상 운영 lock으로 사용하지 않습니다.
# 현재 push 자체는 차단하지 않고, 위험한 secret 파일 변경만 방지합니다.

if git status --short -- .secrets.env .secrets .env.local n8n-automation/.secrets | grep -q .; then
  echo "ERROR: 인증키/환경 파일 변경이 감지되어 push를 중단합니다." >&2
  git status --short -- .secrets.env .secrets .env.local n8n-automation/.secrets >&2
  exit 1
fi

exit 0
