# Naver Search Ad API (HMAC-SHA256)
NAVER_SA_API_KEY=
NAVER_SA_SECRET_KEY=
NAVER_SA_CUSTOMER_ID=

# Naver Commerce API (OAuth2 bcrypt)
NAVER_COMMERCE_CLIENT_ID=
NAVER_COMMERCE_CLIENT_SECRET=

# Naver Developer Center (DataLab)
NAVER_DEV_CLIENT_ID=
NAVER_DEV_CLIENT_SECRET=

# HTTP API (Phase 3 — n8n integration)
API_SECRET_KEY=
API_PORT=8400

# Write guard (default: false = read-only mode)
MCP_WRITE_ENABLED=false

# Safety limits
MAX_BID_DELTA_PCT=20
MAX_AUTO_ACTIONS_PER_DAY=100

# Logging
LOG_LEVEL=INFO
