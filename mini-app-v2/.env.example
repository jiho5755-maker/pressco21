VITE_OMX_FORCE_MOCK=false
# 운영 권장: same-origin proxy (/api/omx/*)를 사용하고 shared key는 브라우저에 두지 않는다.
# 로컬에서 n8n webhook을 직접 두드릴 때만 아래 값을 채운다.
# VITE_OMX_SHARED_KEY=replace-with-omx-shared-key
VITE_OMX_SMARTSTORE_FETCH_URL=/api/omx/smartstore/inquiries?onlyPending=true
VITE_OMX_SMARTSTORE_SEND_URL=/api/omx/smartstore/replies
VITE_OMX_MAKESHOP_FETCH_URL=/api/omx/makeshop/items
VITE_OMX_MAKESHOP_SEND_URL=/api/omx/makeshop/replies
