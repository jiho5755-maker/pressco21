{
  "expo": {
    "name": "프레스코21 - 꽃으로 노는 모든 방법",
    "slug": "pressco21",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "pressco21",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#e5eae3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pressco21.app",
      "infoPlist": {
        "NSCameraUsageDescription": "리뷰 사진 촬영 및 작품 갤러리 업로드를 위해 카메라가 필요합니다.",
        "NSPhotoLibraryUsageDescription": "리뷰 사진 및 작품 갤러리 이미지를 선택하기 위해 사진 라이브러리 접근이 필요합니다."
      }
    },
    "android": {
      "package": "com.pressco21.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e5eae3"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#597051"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
