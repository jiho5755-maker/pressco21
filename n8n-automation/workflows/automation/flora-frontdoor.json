{
  "name": "[F0] Flora Frontdoor (업무방 게이트웨이)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "flora-incoming",
        "responseMode": "onReceived",
        "responseData": "firstEntryJson",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 400],
      "id": "node-trigger",
      "name": "Flora 텔레그램 수신",
      "webhookId": "flora-incoming"
    },
    {
      "parameters": {
        "jsCode": "// Flora Frontdoor - 메시지 파싱 + 키워드 라우팅\n// Phase 3A + 3B 통합 라우터\nconst raw = $input.first().json;\nconst update = raw.body || raw;\nconst message = update.message || {};\nconst text = (message.text || '').trim();\nconst chatId = String(message.chat?.id || '');\nconst messageId = String(message.message_id || '');\nconst fromId = String(message.from?.id || '');\nconst firstName = message.from?.first_name || '대표';\n\n// 허용 채팅방 (업무방=대표 DM, Claude방, Codex방)\nconst ALLOWED_CHATS = ['7713811206', '-5043778307', '-5198284773'];\n\n// 봇 멘션 처리 (그룹에서 @pressco21_openclaw_bot 제거)\nconst cleanText = text.replace(/@pressco21_openclaw_bot\\b/gi, '').trim();\n\nif (!ALLOWED_CHATS.includes(chatId) || !cleanText) {\n  return [{ json: { route: 'ignore', chatId, text: cleanText } }];\n}\n\n// === 키워드 기반 라우팅 (우선순위 순) ===\nlet route = 'task';\nlet subRoute = null;\nlet agentPrompt = cleanText;\n\n// [Phase 3B] 팀미팅 - 복합 분석\nif (/팀미팅|팀 미팅|다각도|여러 관점|전문가 분석|team.?meeting/i.test(cleanText)) {\n  route = 'team-meeting';\n  agentPrompt = `/team-meeting ${cleanText.replace(/팀미팅|팀 미팅|다각도|여러 관점|전문가 분석|team.?meeting/gi, '').trim()}`;\n\n// [Phase 3A] 기획안\n} else if (/기획안|상세페이지|PRD|랜딩페이지|이벤트.*기획|sns.*기획/i.test(cleanText)) {\n  route = 'prd';\n\n// [Phase 3B] Codex 코딩 작업\n} else if (/코드|구현해|버그|리팩토링|테스트 코드|자동화 스크립트|작성해줘.*코드/i.test(cleanText)) {\n  route = 'codex';\n  agentPrompt = cleanText;\n\n// [Phase 3B] Claude 전문가 분석 (20자 이상 복잡한 질문)\n} else if (/전략|마케팅 전략|운영 개선|재무 분석|법률 자문|광고 전략|사업 방향/i.test(cleanText) && cleanText.length > 20) {\n  route = 'agent';\n  // 도메인 매핑\n  if (/전략|사업 방향|방향성|시장 진출/i.test(cleanText)) subRoute = 'cso';\n  else if (/마케팅|광고|브랜딩|콘텐츠 전략|sns 전략/i.test(cleanText)) subRoute = 'cmo';\n  else if (/운영|물류|cs|배송|프로세스 개선/i.test(cleanText)) subRoute = 'coo';\n  else if (/재무|수익성|투자|비용 분석|마진/i.test(cleanText)) subRoute = 'cfo';\n  else if (/기술|개발 방향|시스템|아키텍처|자동화 전략/i.test(cleanText)) subRoute = 'cto';\n  else subRoute = 'cso';\n\n// [Phase 3A] 비즈니스 데이터 조회\n} else if (/매출|주문|revenue|sales/i.test(cleanText)) {\n  route = 'biz';\n  subRoute = 'sales';\n} else if (/고객|세그먼트|rfm|crm/i.test(cleanText)) {\n  route = 'biz';\n  subRoute = 'segments';\n} else if (/파트너|강사/i.test(cleanText)) {\n  route = 'biz';\n  subRoute = 'partners';\n} else if (/캠페인|sms|발송/i.test(cleanText)) {\n  route = 'biz';\n  subRoute = 'campaigns';\n}\n\nreturn [{\n  json: {\n    route, subRoute, agentPrompt,\n    chatId, messageId, fromId, firstName,\n    text: cleanText,\n    rawText: text\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 400],
      "id": "node-parse",
      "name": "메시지 파싱 + 라우팅"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
                "conditions": [{ "id": "c1", "leftValue": "={{ $json.route }}", "rightValue": "prd", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "prd"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
                "conditions": [{ "id": "c2", "leftValue": "={{ $json.route }}", "rightValue": "biz", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "biz"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
                "conditions": [{ "id": "c3", "leftValue": "={{ $json.route }}", "rightValue": "team-meeting", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "team-meeting"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
                "conditions": [{ "id": "c4", "leftValue": "={{ $json.route }}", "rightValue": "agent", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "agent"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
                "conditions": [{ "id": "c5", "leftValue": "={{ $json.route }}", "rightValue": "codex", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "codex"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
                "conditions": [{ "id": "c6", "leftValue": "={{ $json.route }}", "rightValue": "task", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "task"
            }
          ]
        },
        "options": { "fallbackOutput": "none" }
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [480, 400],
      "id": "node-switch",
      "name": "라우트 분기"
