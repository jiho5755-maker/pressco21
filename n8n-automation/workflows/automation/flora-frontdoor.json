    },
    "기획안 트리거 (F13)": { "main": [[{ "node": "기획안 접수 확인", "type": "main", "index": 0 }]] },
    "비즈니스 데이터 조회": { "main": [[{ "node": "비즈니스 데이터 응답", "type": "main", "index": 0 }]] },
    "태스크 등록 (F12)": { "main": [[{ "node": "태스크 등록 확인", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
