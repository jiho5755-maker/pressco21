{
  "name": "[F16] Flora 팀미팅/복합분석 트리거",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "flora-team-meeting",
        "responseMode": "responseNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 300],
      "id": "node-webhook",
      "name": "팀미팅 요청",
      "webhookId": "flora-team-meeting"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst topic = (body.topic || body.text || '').trim();\nconst chatId = String(body.chatId || body.chat_id || '7713811206');\n\nif (!topic) {\n  return [{ json: { ok: false, error: 'topic is required' } }];\n}\n\nconst prompt = `/team-meeting ${topic}`;\n\nreturn [{ json: { ok: true, prompt, topic, chatId } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 300],
      "id": "node-parse",
      "name": "요청 파싱"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [{
            "id": "c1",
            "leftValue": "={{ $json.ok }}",
            "rightValue": true,
            "operator": { "type": "boolean", "operation": "equals" }
          }],
          "combinator": "and"
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [660, 300],
      "id": "node-if",
      "name": "유효성"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://mini.pressco21.com/api/automation/dev-queue",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-flora-automation-key", "value": "={{ $env.ADMIN_API_TOKEN }}" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ worker: 'claude', prompt: $json.prompt, chatId: '-5043778307' }) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 200],
      "id": "node-queue",
      "name": "Claude 큐 등록"
    },
    {
      "parameters": {
        "chatId": "={{ $('요청 파싱').first().json.chatId }}",
        "text": "={{ '\\u{1F91D} <b>[\\uD300\\uBBF8\\uD305]</b> ' + $('요청 파싱').first().json.topic + '\\n\\nC-Suite \\uC5D0\\uC774\\uC804\\uD2B8\\uB4E4\\uC774 \\uBD84\\uC11D \\uC911\\uC785\\uB2C8\\uB2E4. \\uC644\\uB8CC\\uB418\\uBA74 \\uC54C\\uB824\\uB4DC\\uB9AC\\uACA0\\uC2B5\\uB2C8\\uB2E4.' }}",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1140, 200],
      "id": "node-notify",
      "name": "접수 확인",
      "credentials": {
        "telegramApi": { "id": "eS5YwFGpbJht6uCB", "name": "PRESSCO21-Telegram-Bot" }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, queued: true, topic: $('요청 파싱').first().json.topic }) }}"
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1380, 200],
      "id": "node-respond-ok",
      "name": "성공"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: $('요청 파싱').first().json.error }) }}",
        "options": { "responseCode": 400 }
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [900, 420],
      "id": "node-respond-err",
      "name": "에러"
    }
  ],
  "connections": {
    "팀미팅 요청": { "main": [[{ "node": "요청 파싱", "type": "main", "index": 0 }]] },
    "요청 파싱": { "main": [[{ "node": "유효성", "type": "main", "index": 0 }]] },
    "유효성": {
      "main": [
        [{ "node": "Claude 큐 등록", "type": "main", "index": 0 }],
        [{ "node": "에러", "type": "main", "index": 0 }]
      ]
    },
    "Claude 큐 등록": { "main": [[{ "node": "접수 확인", "type": "main", "index": 0 }]] },
    "접수 확인": { "main": [[{ "node": "성공", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
