{
  "name": "[F4] Flora 밀린 업무 알림 (10:00)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "triggerAtHour": 10, "triggerAtMinute": 0 }]
        }
      },
      "id": "node-schedule",
      "name": "매일 10:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://flora-todo-mvp:3000/api/automation/briefings/overdue?limit=20",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-flora-automation-key", "value": "={{ $env.ADMIN_API_TOKEN }}" }
          ]
        }
      },
      "id": "node-flora-overdue-brief",
      "name": "Flora 밀린 업무 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-send-alert",
              "leftValue": "={{ $json.shouldSend }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "node-should-send",
      "name": "발송 필요?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "chatId": "7713811206",
        "text": "={{ $json.text }}",
        "additionalFields": {}
      },
      "id": "node-send",
      "name": "텔레그램 발송",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [660, 260],
      "credentials": {
        "telegramApi": {
          "id": "eS5YwFGpbJht6uCB",
          "name": "PRESSCO21-Telegram-Bot"
        }
      }
    }
  ],
  "connections": {
    "매일 10:00": {
      "main": [[{ "node": "Flora 밀린 업무 조회", "type": "main", "index": 0 }]]
    },
    "Flora 밀린 업무 조회": {
      "main": [[{ "node": "발송 필요?", "type": "main", "index": 0 }]]
    },
    "발송 필요?": {
      "main": [
        [{ "node": "텔레그램 발송", "type": "main", "index": 0 }],
        []
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "Asia/Seoul"
  },
  "tags": [{ "name": "업무자동화" }]
}
