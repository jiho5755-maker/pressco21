{
  "name": "PRD-SAVE: 기획안 저장 + 핸드오프",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "prd-save",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-save",
      "name": "저장 웹훅",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "prd-save"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://nocodb.pressco21.com/api/v1/db/data/noco/{{ $env.NOCODB_PRD_PROJECT_ID }}/{{ $env.NOCODB_PRD_TABLE_ID }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "xc-token", "value": "={{ $env.NOCODB_API_TOKEN }}" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.body || $json) }}",
        "options": {}
      },
      "id": "save-nocodb",
      "name": "NocoDB 저장",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300]
    },
    {
      "parameters": {
        "jsCode": "const row = $input.first().json;\nconst id = row.Id || row.id || '?';\nconst title = row.title || '기획안';\nconst typeName = row.prd_type || '';\nconst preview = (row.content_md || '').slice(0, 500).replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));\n\nconst msg = [\n  '<b>[기획안 저장 완료]</b>',\n  '',\n  `<b>제목</b>: \\${title}`,\n  `<b>유형</b>: \\${typeName}`,\n  `<b>NocoDB ID</b>: #\\${id}`,\n  '',\n  `<pre>\\${preview}...</pre>`,\n  '',\n  `승인: \"기획안 승인 #\\${id}\"`,\n  `배정: \"기획안 배정 #\\${id} 다경\"`\n].join('\\n');\n\nreturn [{ json: { message: msg, id } }];"
      },
      "id": "build-msg",
      "name": "알림 메시지 구성",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 300]
    },
    {
      "parameters": {
        "chatId": "-5043778307",
        "text": "={{ $json.message }}",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "telegram-notify",
      "name": "텔레그램 알림 (Claude 개발방)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [960, 300],
      "credentials": {
        "telegramApi": { "id": "RdFu3nsFuuO5NCff", "name": "Telegram Makeshop Bot" }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, id: $('NocoDB 저장').first().json.Id || $('NocoDB 저장').first().json.id }) }}"
      },
      "id": "respond-ok",
      "name": "성공 응답",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1200, 300]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "prd-action",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-action",
      "name": "핸드오프 웹훅",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 600],
      "webhookId": "prd-action"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst text = (body.text || '').trim();\n\nconst approveMatch = text.match(/기획안\\s*승인\\s*#?(\\d+)/);\nconst assignMatch = text.match(/기획안\\s*배정\\s*#?(\\d+)\\s+(.+)/);\n\nif (approveMatch) {\n  const now = new Date();\n  const kst = new Date(now.getTime() + 9*60*60*1000).toISOString().slice(0,10);\n  return [{ json: { action: 'approve', rowId: parseInt(approveMatch[1]), patch: { status: 'approved', approved_date: kst } } }];\n} else if (assignMatch) {\n  return [{ json: { action: 'assign', rowId: parseInt(assignMatch[1]), patch: { status: 'assigned', assignee: assignMatch[2].trim() } } }];\n}\nreturn [{ json: { action: 'error', error: '예: 기획안 승인 #1 / 기획안 배정 #1 다경' } }];"
      },
      "id": "parse-action",
      "name": "액션 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 600]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{ "id": "c1", "leftValue": "={{ $json.action }}", "rightValue": "error", "operator": { "type": "string", "operation": "notEquals" } }],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-valid-action",
      "name": "유효성",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [720, 600]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://nocodb.pressco21.com/api/v1/db/data/noco/{{ $env.NOCODB_PRD_PROJECT_ID }}/{{ $env.NOCODB_PRD_TABLE_ID }}/{{ $json.rowId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "xc-token", "value": "={{ $env.NOCODB_API_TOKEN }}" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.patch) }}",
        "options": {}
      },
      "id": "patch-nocodb",
      "name": "NocoDB 업데이트",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [960, 560]
    },
    {
      "parameters": {
        "jsCode": "const prev = $('액션 파싱').first().json;\nconst row = $input.first().json;\nconst title = row.title || '기획안';\nlet msg = '';\nif (prev.action === 'approve') {\n  msg = `<b>[승인 완료]</b> #\\${prev.rowId} \\${title}\\n배정: \\\"기획안 배정 #\\${prev.rowId} 다경\\\"`;\n} else {\n  msg = `<b>[배정 완료]</b> #\\${prev.rowId} \\${title} → \\${prev.patch.assignee}`;\n}\nreturn [{ json: { message: msg } }];"
      },
      "id": "action-msg",
      "name": "결과 메시지",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 560]
    },
    {
      "parameters": {
        "chatId": "-5043778307",
        "text": "={{ $json.message }}",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "telegram-action",
      "name": "텔레그램 액션 알림 (Claude 개발방)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1440, 560],
      "credentials": {
        "telegramApi": { "id": "RdFu3nsFuuO5NCff", "name": "Telegram Makeshop Bot" }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, action: $('액션 파싱').first().json.action }) }}"
      },
      "id": "respond-action-ok",
      "name": "액션 성공",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1680, 560]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: false, error: $json.error }) }}",
        "options": { "responseCode": 400 }
      },
      "id": "respond-action-err",
      "name": "액션 에러",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [960, 720]
    }
  ],
  "connections": {
    "저장 웹훅": { "main": [[{ "node": "NocoDB 저장", "type": "main", "index": 0 }]] },
    "NocoDB 저장": { "main": [[{ "node": "알림 메시지 구성", "type": "main", "index": 0 }]] },
    "알림 메시지 구성": { "main": [[{ "node": "텔레그램 알림 (Claude 개발방)", "type": "main", "index": 0 }]] },
    "텔레그램 알림 (Claude 개발방)": { "main": [[{ "node": "성공 응답", "type": "main", "index": 0 }]] },
    "핸드오프 웹훅": { "main": [[{ "node": "액션 파싱", "type": "main", "index": 0 }]] },
    "액션 파싱": { "main": [[{ "node": "유효성", "type": "main", "index": 0 }]] },
    "유효성": { "main": [[{ "node": "NocoDB 업데이트", "type": "main", "index": 0 }], [{ "node": "액션 에러", "type": "main", "index": 0 }]] },
    "NocoDB 업데이트": { "main": [[{ "node": "결과 메시지", "type": "main", "index": 0 }]] },
    "결과 메시지": { "main": [[{ "node": "텔레그램 액션 알림 (Claude 개발방)", "type": "main", "index": 0 }]] },
    "텔레그램 액션 알림 (Claude 개발방)": { "main": [[{ "node": "액션 성공", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
