    "미발송 주문 필터": { "main": [[{ "node": "대상 있는지 체크", "type": "main", "index": 0 }]] },
    "대상 있는지 체크": { "main": [[{ "node": "알리고 배송 알림톡", "type": "main", "index": 0 }], [{ "node": "대상 없음 종료", "type": "main", "index": 0 }]] },
