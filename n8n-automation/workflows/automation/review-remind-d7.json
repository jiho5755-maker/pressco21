      "id": "b1000001-0001-4000-8000-000000000004",
      "name": "NocoDB 기발송 리마인더",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 400]
    },
    {
      "parameters": {
        "jsCode": "// 7일전 배송 알림 발송 기록 (리마인더 대상 후보)\nconst deliveryData = $('NocoDB 7일전 배송알림 조회').first().json;\nconst reviewData = $('최근 리뷰 전체 조회').first().json;\nconst remindData = $('NocoDB 기발송 리마인더').first().json;\n\n// 7일전 배송 알림 발송 목록\nconst deliveryRows = deliveryData.list || [];\nif (deliveryRows.length === 0) {\n  return [{ json: { empty: true, message: 'D+7 리마인더 대상 없음 (배송 알림 기록 없음)' } }];\n}\n\n// 이미 리뷰 작성한 주문번호 Set\nconst reviewedOrders = new Set();\nconst reviews = reviewData.list || [];\nconst reviewList = Array.isArray(reviews) ? reviews : Object.values(reviews);\nfor (const review of reviewList) {\n  if (review.ordernum) reviewedOrders.add(review.ordernum);\n}\n\n// 이미 리마인더 발송한 주문번호 Set\nconst remindedOrders = new Set();\nconst remindRows = remindData.list || [];\nfor (const row of remindRows) {\n  if (row.order_id) remindedOrders.add(row.order_id);\n}\n\n// 필터: 리뷰 미작성 + 리마인더 미발송\nconst results = [];\nfor (const row of deliveryRows) {\n  const orderId = row.order_id;\n  if (!orderId) continue;\n  if (reviewedOrders.has(orderId)) continue; // 이미 리뷰 작성\n  // 주문번호 부분 매칭 (리뷰 ordernum에 _1 등 접미사)\n  let hasReview = false;\n  for (const rid of reviewedOrders) {\n    if (rid && rid.startsWith(orderId)) { hasReview = true; break; }\n  }\n  if (hasReview) continue;\n  if (remindedOrders.has(orderId)) continue; // 이미 리마인더 발송\n\n  const phone = (row.customer_phone || '').trim();\n  if (!phone || phone.length < 10) continue;\n\n  results.push({\n    json: {\n      order_id: orderId,\n      customer_name: row.customer_name || '고객',\n      customer_phone: phone,\n      product_name: '주문 상품'\n    }\n  });\n}\n\nreturn results.length > 0 ? results : [{ json: { empty: true, message: 'D+7 리마인더 대상 없음 (모두 리뷰 작성 완료)' } }];"
      },
      "id": "b1000001-0001-4000-8000-000000000005",
      "name": "리뷰 미작성 필터",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 200]
    },
