            { "name": "sender", "value": "={{ $env.ALIGO_SENDER_PHONE }}" },
            { "name": "receiver_1", "value": "={{ $json.customer_phone }}" },
            { "name": "subject_1", "value": "리뷰 작성 부탁드려요" },
            { "name": "message_1", "value": "={{ '[프레스코21] ' + $json.customer_name + '님, 주문하신 ' + $json.product_name + ' 잘 받으셨나요?\\n\\n' + $json.customer_name + '님의 솔직한 후기가 다른 고객님들께 큰 도움이 됩니다.\\n\\n■ 포토 후기: 500원 적립금\\n■ 텍스트 후기: 200원 적립금\\n\\n한 줄이라도 좋으니 후기를 남겨주세요!' }}" },
            { "name": "failover", "value": "Y" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
