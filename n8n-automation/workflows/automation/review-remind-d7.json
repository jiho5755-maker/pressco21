        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "where", "value": "(notification_type,eq,REVIEW_REMIND)" },
            { "name": "limit", "value": "1000" },
            { "name": "fields", "value": "order_id" }
          ]
        },
