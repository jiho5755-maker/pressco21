            { "name": "InquiryTimeTo", "value": "={{ $now.minus({days:1}).toFormat('yyyy-MM-dd') }} 23:59:59" },
            { "name": "limit", "value": "100" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Shopkey", "value": "={{ $env.MAKESHOP_SHOPKEY }}" },
            { "name": "Licensekey", "value": "={{ $env.MAKESHOP_LICENSEKEY }}" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "c1000001-0001-4000-8000-000000000002",
      "name": "파워리뷰 어제 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://nocodb.pressco21.com/api/v2/tables/' + $env.NOCODB_TABLE_REVIEW_REWARD + '/records' }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "limit", "value": "1000" },
            { "name": "fields", "value": "board_num" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "xc-token", "value": "={{ $env.NOCODB_TOKEN }}" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "c1000001-0001-4000-8000-000000000003",
      "name": "NocoDB 기존 적립금 기록",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 200]
    },
    {
      "parameters": {
        "jsCode": "// 파워리뷰 응답에서 리뷰 목록 추출\nconst reviewData = $('파워리뷰 어제 조회').first().json;\nconst rewardData = $('NocoDB 기존 적립금 기록').first().json;\n\n// 리뷰 목록 파싱\nconst reviews = reviewData.list || [];\nconst reviewList = Array.isArray(reviews) ? reviews : Object.values(reviews);\n\nif (reviewList.length === 0) {\n  return [{ json: { empty: true, message: '어제 신규 리뷰 없음' } }];\n}\n\n// 이미 적립금 지급한 게시글 번호 Set\nconst existingNums = new Set();\nconst rows = rewardData.list || [];\nfor (const row of rows) {\n  if (row.board_num) existingNums.add(String(row.board_num));\n}\n\n// 신규 리뷰 필터 + 포토/텍스트 구분\nconst results = [];\nfor (const review of reviewList) {\n  const boardNum = String(review.num1);\n  if (existingNums.has(boardNum)) continue;\n\n  // 포토 구분: content에 <img 태그가 있으면 포토\n  const content = review.content || '';\n  const isPhoto = content.includes('<img') || content.includes('phinf.pstatic.net');\n  const rewardAmount = 200; // 포토/텍스트 동일 200원 (2026-04-02 대표 확정)\n  const reviewType = isPhoto ? 'PHOTO' : 'TEXT';\n\n  // 네이버페이 리뷰는 회원ID가 없을 수 있음\n  const customerId = review.id || '';\n  if (!customerId) continue; // 회원ID 없으면 적립금 지급 불가\n\n  results.push({\n    json: {\n      board_num: boardNum,\n      order_id: review.ordernum || '',\n      customer_id: customerId,\n      customer_name: review.hname || '고객',\n      review_type: reviewType,\n      reward_amount: rewardAmount,\n      review_date: review.reg_date,\n      write_path: review.write_path || 'WEB'\n    }\n  });\n}\n\nreturn results.length > 0 ? results : [{ json: { empty: true, message: '지급 대상 없음' } }];"
      },
      "id": "c1000001-0001-4000-8000-000000000004",
      "name": "신규 리뷰 필터 + 포토 구분",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 100]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-empty",
              "leftValue": "={{ $json.empty }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "notTrue" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "c1000001-0001-4000-8000-000000000005",
      "name": "대상 있는지 체크",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [700, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://foreverlove.co.kr/list/open_api_process.html",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "mode", "value": "save" },
            { "name": "type", "value": "reserve" },
            { "name": "process", "value": "give" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Shopkey", "value": "={{ $env.MAKESHOP_SHOPKEY }}" },
            { "name": "Licensekey", "value": "={{ $env.MAKESHOP_LICENSEKEY }}" },
            { "name": "Content-Type", "value": "application/x-www-form-urlencoded" }
          ]
        },
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            { "name": "datas[0][userid]", "value": "={{ $json.customer_id }}" },
            { "name": "datas[0][reserve]", "value": "={{ $json.reward_amount }}" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "c1000001-0001-4000-8000-000000000006",
      "name": "MakeShop 적립금 지급",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [940, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://kakaoapi.aligo.in/akv10/alimtalk/send/",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.ALIGO_API_KEY }}" },
            { "name": "userid", "value": "={{ $env.ALIGO_USER_ID }}" },
            { "name": "senderkey", "value": "={{ $env.ALIGO_SENDER_KEY }}" },
            { "name": "tpl_code", "value": "={{ $env.ALIGO_TPL_REWARD }}" },
            { "name": "sender", "value": "={{ $env.ALIGO_SENDER_PHONE }}" },
            { "name": "receiver_1", "value": "={{ $('MakeShop 적립금 지급').item.json.customer_phone || '' }}" },
            { "name": "subject_1", "value": "적립금 지급 완료" },
            { "name": "message_1", "value": "={{ '[프레스코21] ' + $json.customer_name + '님, 후기 감사합니다!\\n\\n' + $json.review_type + ' 후기 작성 감사 적립금이 지급되었습니다.\\n\\n■ 지급 적립금: ' + $json.reward_amount + '원\\n\\n적립금은 다음 주문 시 사용하실 수 있습니다.\\n항상 감사합니다!' }}" },
            { "name": "failover", "value": "Y" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "c1000001-0001-4000-8000-000000000007",
      "name": "알리고 적립금 알림톡",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1160, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://nocodb.pressco21.com/api/v2/tables/' + $env.NOCODB_TABLE_REVIEW_REWARD + '/records' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "xc-token", "value": "={{ $env.NOCODB_TOKEN }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  board_num: $json.board_num,\n  order_id: $json.order_id,\n  customer_id: $json.customer_id,\n  customer_name: $json.customer_name,\n  review_type: $json.review_type,\n  reward_amount: $json.reward_amount,\n  reward_status: 'SUCCESS',\n  review_date: $json.review_date,\n  reward_date: $now.toISO()\n}) }}",
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "c1000001-0001-4000-8000-000000000008",
      "name": "NocoDB 적립금 기록",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1380, 0]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet successCount = 0;\nlet failCount = 0;\nlet totalReward = 0;\n\nfor (const item of items) {\n  if (item.json.reward_status === 'SUCCESS') {\n    successCount++;\n    totalReward += (item.json.reward_amount || 0);\n  } else {\n    failCount++;\n  }\n}\n\nconst now = new Date().toISOString();\nconst message = `📊 리뷰 적립금 자동 지급 완료\\n\\n✅ 성공: ${successCount}건\\n❌ 실패: ${failCount}건\\n💰 총 지급: ${totalReward.toLocaleString()}원\\n⏰ ${now}`;\n\nreturn [{ json: { message, successCount, failCount, totalReward } }];"
      },
      "id": "c1000001-0001-4000-8000-000000000009",
      "name": "통계 집계",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1600, 0]
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID || '-5154731145' }}",
        "text": "={{ $json.message }}",
        "additionalFields": {}
