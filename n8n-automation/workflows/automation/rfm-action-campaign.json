    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://nocodb.pressco21.com/api/v2/tables/' + $env.NOCODB_TABLE_CAMPAIGN_LOG + '/records' }}",
        "sendHeaders": true,
        "headerParameters": {
