      "id": "rfm-act-0001-4000-8000-000000000004",
      "name": "MakeShop 회원정보 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        720,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// RFM-ACTION: 세그먼트별 발송 대상 필터링 + 메시지 생성\n// 입력: 세그먼트 목록, 7일내 발송기록, 회원 연락처\n\nconst segData = $('NocoDB 세그먼트 조회').first().json;\nconst logData = $('NocoDB 7일내 발송기록').first().json;\nconst memberData = $('MakeShop 회원정보 조회').first().json;\n\n// 배열 변환 유틸\nfunction toArray(data) {\n  if (Array.isArray(data)) return data;\n  if (data && typeof data === 'object') return Object.values(data);\n  return [];\n}\n\nconst segments = toArray(segData.list || []);\nconst recentLogs = toArray(logData.list || []);\nconst members = toArray(memberData.list || []);\n\n// 회원 연락처 맵 (user_id -> phone)\nconst phoneMap = {};\nfor (const m of members) {\n  const uid = m.id || m.userid;\n  const phone = (m.cellphone || m.phone || '').replace(/-/g, '').trim();\n  if (uid && phone && phone.length >= 10) {\n    phoneMap[uid] = phone;\n  }\n}\n\n// 7일 이내 발송된 user_id+segment 조합 Set (중복 방지)\nconst sentSet = new Set();\nfor (const log of recentLogs) {\n  if (log.user_id && log.segment) {\n    sentSet.add(log.user_id + '::' + log.segment);\n  }\n}\n\n// 세그먼트별 메시지 템플릿\nconst templates = {\n  '이탈위험': function(name) {\n    return '[프레스코21] ' + name + '님, 오랜만이에요!\\n'\n      + '요즘 새로운 재료들이 많이 들어왔어요.\\n'\n      + '다시 한번 둘러보시겠어요?\\n'\n      + '> foreverlove.co.kr';\n  },\n  '신규고객': function(name) {\n    return '[프레스코21] ' + name + '님, 첫 주문 감사합니다!\\n'\n      + '이 재료와 같이 쓰면 더 예쁜 작품을 만들 수 있어요.\\n'\n      + '> foreverlove.co.kr';\n  },\n  'VIP': function(name) {\n    return '[프레스코21] ' + name + '님, 항상 감사합니다.\\n'\n      + '이번 주 신상품을 먼저 알려드려요!\\n'\n      + '> foreverlove.co.kr';\n  },\n  '휴면고객': function(name) {\n    return '[프레스코21] ' + name + '님, 꽃 공예가 그리우시죠?\\n'\n      + '돌아오시면 반갑겠습니다.\\n'\n      + '> foreverlove.co.kr';\n  }\n};\n\n// 세그먼트별 최대 발송 수 (주당)\nconst maxPerSegment = {\n  '이탈위험': 100,\n  '신규고객': 100,\n  'VIP': 100,\n  '휴면고객': 100\n};\n\n// 세그먼트별 카운터\nconst segCounter = {};\nconst results = [];\n\nfor (const seg of segments) {\n  const uid = seg.user_id;\n  const segName = seg.segment;\n  if (!uid || !segName) continue;\n\n  // 대상 세그먼트만\n  if (!templates[segName]) continue;\n\n  // 세그먼트별 최대 발송 수 체크\n  segCounter[segName] = (segCounter[segName] || 0);\n  if (segCounter[segName] >= (maxPerSegment[segName] || 100)) continue;\n\n  // 7일 이내 같은 세그먼트 캠페인 이미 발송?\n  const key = uid + '::' + segName;\n  if (sentSet.has(key)) continue;\n\n  // 연락처 존재 여부\n  const phone = phoneMap[uid];\n  if (!phone) continue;\n\n  // 메시지 생성\n  const custName = seg.user_name || '고객';\n  const msg = templates[segName](custName);\n\n  results.push({\n    json: {\n      user_id: uid,\n      user_name: custName,\n      segment: segName,\n      phone: phone,\n      message: msg,\n      order_count: seg.order_count || 0,\n      total_spent: seg.total_spent || 0,\n      recency_days: seg.recency_days || 0\n    }\n  });\n\n  segCounter[segName]++;\n}\n\n// 통계\nconst stats = {\n  total: results.length,\n  bySegment: segCounter,\n  skippedNoPhone: segments.filter(s => !phoneMap[s.user_id] && templates[s.segment]).length,\n  skippedDuplicate: segments.filter(s => sentSet.has(s.user_id + '::' + s.segment) && templates[s.segment]).length\n};\n\nif (results.length === 0) {\n  return [{ json: { empty: true, message: 'RFM 캠페인 발송 대상 없음', stats: stats } }];\n}\n\n// 첫 아이템에 stats 삽입 (집계용)\nresults[0].json._stats = stats;\n\nreturn results;"
      },
