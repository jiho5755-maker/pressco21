      "id": "rfm-act-0001-4000-8000-000000000003",
      "name": "NocoDB 7일내 발송기록",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// 대상 세그먼트 필터링 (전화번호 조회 전)\nconst segData = $('NocoDB 세그먼트 조회').first().json;\nconst logData = $('NocoDB 7일내 발송기록').first().json;\n\nfunction toArray(data) {\n  if (Array.isArray(data)) return data;\n  if (data && typeof data === 'object') return Object.values(data);\n  return [];\n}\n\nconst segments = toArray(segData.list || []);\nconst recentLogs = toArray(logData.list || []);\n\nconst now = Date.now();\nconst sevenDaysAgo = now - 7 * 24 * 60 * 60 * 1000;\nconst sentSet = new Set();\nfor (const log of recentLogs) {\n  const sentTime = new Date(log.sent_at || 0).getTime();\n  if (sentTime > sevenDaysAgo && log.user_id && log.segment) {\n    sentSet.add(log.user_id + '::' + log.segment);\n  }\n}\n\nconst targetSegments = ['이탈위험', '신규고객', 'VIP', '휴면고객'];\nconst maxPerSegment = 100;\nconst segCounter = {};\nconst results = [];\n\nfor (const seg of segments) {\n  const uid = seg.user_id;\n  const segName = seg.segment;\n  if (!uid || !segName || !targetSegments.includes(segName)) continue;\n\n  segCounter[segName] = (segCounter[segName] || 0);\n  if (segCounter[segName] >= maxPerSegment) continue;\n  if (sentSet.has(uid + '::' + segName)) continue;\n\n  results.push({\n    json: {\n      user_id: uid,\n      user_name: seg.user_name || '',\n      segment: segName,\n      order_count: seg.order_count || 0,\n      total_spent: seg.total_spent || 0,\n      recency_days: seg.recency_days || 0\n    }\n  });\n  segCounter[segName]++;\n}\n\nif (results.length === 0) {\n  return [{ json: { empty: true, message: '대상 없음: ' + JSON.stringify(segCounter) } }];\n}\n\nreturn results;"
      },
      "id": "rfm-act-0001-4000-8000-000000000004",
      "name": "세그먼트 필터",
