      "id": "rfm-act-0001-4000-8000-000000000009",
      "name": "NocoDB 발송기록 저장",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        200
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// RFM 캠페인 발송 결과 집계\nconst items = $input.all();\nconst segCount = {};\nlet total = 0;\n\nfor (const item of items) {\n  const seg = item.json.segment;\n  if (!seg) continue;\n  segCount[seg] = (segCount[seg] || 0) + 1;\n  total++;\n}\n\nconst now = new Date();\nconst kst = new Date(now.getTime() + 9 * 60 * 60 * 1000);\nconst timeStr = kst.toISOString().replace('T', ' ').substring(0, 19) + ' KST';\n\nlet msg = '<b>RFM-ACTION 캠페인 발송 완료</b>\\n';\nmsg += '\\n';\nmsg += 'SMS ' + total + '건 발송 (테스트 모드)\\n\\n';\n\nconst segOrder = ['이탈위험', '신규고객', 'VIP', '휴면고객'];\nconst emojiMap = { '이탈위험': '\\u26a0\\ufe0f', '신규고객': '\\ud83c\\udd95', 'VIP': '\\ud83d\\udc51', '휴면고객': '\\ud83d\\ude34' };\n\nfor (const seg of segOrder) {\n  const cnt = segCount[seg] || 0;\n  if (cnt === 0) continue;\n  msg += (emojiMap[seg] || '') + ' ' + seg + ': ' + cnt + '건\\n';\n}\n\nmsg += '\\n' + timeStr;\nmsg += '\\n\\n(testmode_yn=Y, 실제 발송 없음)';\n\nreturn [{ json: { message: msg, total: total, bySegment: segCount } }];"
      },
      "id": "rfm-act-0001-4000-8000-000000000011",
      "name": "발송결과 집계",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
