        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  user_id: $json.user_id,\n  user_name: $json.user_name,\n  segment: $json.segment,\n  phone: $json.phone,\n  channel: 'SMS',\n  status: 'SUCCESS',\n  sent_at: $now.toISO()\n}) }}",
