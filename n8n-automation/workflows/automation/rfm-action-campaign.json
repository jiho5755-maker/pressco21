      "id": "rfm-act-0001-4000-8000-000000000010",
      "name": "MakeShop 회원 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        200
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// MakeShop 응답 + 세그먼트 데이터 조합 → 메시지 생성\nconst mkResponses = $input.all();\nconst segItems = $('대상 있는지 체크').all();\n\nconst messages = {\n  '이탈위험': (name) => '[프레스코21] ' + name + '님, 오랜만이에요!\\n요즘 새로운 재료들이 많이 들어왔어요.\\n다시 한번 둘러보시겠어요?\\n> foreverlove.co.kr',\n  '신규고객': (name) => '[프레스코21] ' + name + '님, 첫 주문 감사합니다!\\n이 재료와 같이 쓰면 더 예쁜 작품을 만들 수 있어요.\\n> foreverlove.co.kr',\n  'VIP': (name) => '[프레스코21] ' + name + '님, 항상 감사합니다.\\n이번 주 신상품을 먼저 알려드려요!\\n> foreverlove.co.kr',\n  '휴면고객': (name) => '[프레스코21] ' + name + '님, 꽃 공예가 그리우시죠?\\n돌아오시면 반갑겠습니다.\\n> foreverlove.co.kr'\n};\n\nconst results = [];\nlet skippedNoPhone = 0;\n\nfor (let i = 0; i < mkResponses.length; i++) {\n  const mkResp = mkResponses[i].json;\n  const seg = segItems[i] ? segItems[i].json : {};\n\n  // MakeShop 응답에서 회원 정보 추출\n  const memberList = mkResp.list || [];\n  const member = memberList[0];\n\n  if (!member || !member.mobile) {\n    skippedNoPhone++;\n    continue;\n  }\n\n  const phone = (member.mobile || '').replace(/-/g, '').trim();\n  if (phone.length < 10) {\n    skippedNoPhone++;\n    continue;\n  }\n\n  const custName = member.hname || seg.user_name || '고객';\n  const segName = seg.segment || '?';\n  const msg = messages[segName] ? messages[segName](custName) : '';\n  if (!msg) continue;\n\n  results.push({\n    json: {\n      user_id: seg.user_id,\n      user_name: custName,\n      segment: segName,\n      phone: phone,\n      message: msg,\n      order_count: seg.order_count || 0,\n      total_spent: seg.total_spent || 0\n    }\n  });\n}\n\nif (results.length === 0) {\n  return [{ json: { empty: true, message: 'SMS 발송 대상 없음 (전화번호 없음: ' + skippedNoPhone + '명)' } }];\n}\n\nreturn results;"
      },
