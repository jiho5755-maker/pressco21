      "id": "rfm-act-0001-4000-8000-000000000012",
      "name": "텔레그램 결과 알림",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1520,
        460
      ],
      "credentials": {
        "telegramApi": {
          "id": "RdFu3nsFuuO5NCff",
          "name": "Telegram Makeshop Bot"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// 대상 없음 — 텔레그램 메시지 생성\nconst data = $input.first().json;\nconst stats = data.stats || {};\n\nconst now = new Date();\nconst kst = new Date(now.getTime() + 9 * 60 * 60 * 1000);\nconst timeStr = kst.toISOString().replace('T', ' ').substring(0, 19) + ' KST';\n\nlet msg = '<b>RFM-ACTION 캠페인</b>\\n\\n';\nmsg += 'SMS 발송 대상 없음\\n\\n';\nif (stats.skippedNoPhone) msg += '- 연락처 없음: ' + stats.skippedNoPhone + '명\\n';\nif (stats.skippedDuplicate) msg += '- 7일내 중복: ' + stats.skippedDuplicate + '명\\n';\nmsg += '\\n' + timeStr;\n\nreturn [{ json: { message: msg } }];"
      },
