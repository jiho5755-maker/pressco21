{
  "name": "[F7] 이재혁 일일 브리핑 (08:00)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "triggerAtHour": 8, "triggerAtMinute": 0 }]
        }
      },
      "id": "node-schedule",
      "name": "매일 08:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://mini.pressco21.com/api/automation/briefings/staff?assignee=이재혁&limit=20",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-flora-automation-key", "value": "={{ $env.ADMIN_API_TOKEN }}" }
          ]
        }
      },
      "id": "node-flora-staff",
      "name": "이재혁 업무 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            { "value1": "={{ $json.shouldSend }}", "value2": true }
          ]
        }
      },
      "id": "node-if-send",
      "name": "발송 여부",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "chatId": "JAEHYUK_CHAT_ID_PLACEHOLDER",
        "text": "={{ $('이재혁 업무 조회').item.json.text }}",
        "additionalFields": {}
      },
      "id": "node-send-staff",
      "name": "텔레그램 발송",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [660, 200],
      "credentials": {
        "telegramApi": {
          "id": "eS5YwFGpbJht6uCB",
          "name": "PRESSCO21-Telegram-Bot"
        }
      }
    }
  ],
  "connections": {
    "매일 08:00": {
      "main": [[{ "node": "이재혁 업무 조회", "type": "main", "index": 0 }]]
    },
    "이재혁 업무 조회": {
      "main": [[{ "node": "발송 여부", "type": "main", "index": 0 }]]
    },
    "발송 여부": {
      "main": [
        [{ "node": "텔레그램 발송", "type": "main", "index": 0 }],
        []
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "Asia/Seoul"
  },
  "tags": [{ "name": "업무자동화" }, { "name": "직원자동화" }]
}
