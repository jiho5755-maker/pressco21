        "jsCode": "const rawItems = $input.all();\nconst events = [];\nfor (const raw of rawItems) {\n  if (raw.json.list && Array.isArray(raw.json.list)) {\n    for (const record of raw.json.list) {\n      events.push(record);\n    }\n  }\n}\nreturn [{ json: { count: events.length, events } }];"
