        "queryParameters": {
          "parameters": [
            {
              "name": "where",
              "value": "(관련도점수,gte,50)~and(상태,eq,데이터 수집)"
            },
            {
              "name": "limit",
              "value": "300"
            },
            {
              "name": "fields",
              "value": "Id,지원사업이름,소관기관,관련도점수,신청Link,카테고리,적합이유,추천이유_상세,마감일"
            }
          ]
        },
        "options": {}
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "ev-node-012",
      "name": "Code 키워드 매칭 포맷",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 60],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const kwData = $('Code 키워드 파싱').item.json;\nconst { keywords, _eventId, _eventName } = kwData;\nconst rawItems = $input.all();\n\n// NocoDB list 확장\nconst records = [];\nfor (const raw of rawItems) {\n  if (raw.json.list && Array.isArray(raw.json.list)) {\n    for (const r of raw.json.list) records.push(r);\n  }\n}\n\n// 키워드 필터링\nconst matches = records.filter(r => {\n  const text = `${r['지원사업이름'] || ''} ${r['적합이유'] || ''} ${r['카테고리'] || ''} ${r['추천이유_상세'] || ''} ${r['소관기관'] || ''}`.toLowerCase();\n  return keywords.some(kw => text.includes(kw.toLowerCase()));\n}).sort((a, b) => (b['관련도점수'] || 0) - (a['관련도점수'] || 0));\n\nconst topMatches = matches.slice(0, 5);\nlet telegramText = '';\n\nif (topMatches.length === 0) {\n  telegramText = `💡 <b>${_eventName}</b> 이벤트 탐색 결과\\n\\n현재 수집된 공고 중 매칭 결과가 없습니다.\\n\\n🔍 검색 키워드: ${keywords.join(', ')}`;\n} else {\n  const matchLines = topMatches.map((m, i) => {\n    const link = m['신청Link'] ? `\\n   🔗 <a href=\"${m['신청Link']}\">신청 바로가기</a>` : '';\n    const deadline = m['마감일'] ? ` | 마감: ${m['마감일']}` : '';\n    return `${i+1}. <b>${m['지원사업이름']}</b>\\n   ${m['소관기관'] || ''} | 점수: ${m['관련도점수']}점${deadline}${link}`;\n  }).join('\\n\\n');\n  telegramText = `💡 <b>[이벤트 탐색] ${_eventName}</b>\\n\\n관련 지원사업 ${matches.length}건 발견! (상위 ${topMatches.length}건 표시)\\n\\n${matchLines}\\n\\n🔍 키워드: ${keywords.join(', ')}`;\n}\n\nreturn [{ json: { _eventId, _eventName, telegramText, matchCount: topMatches.length } }];"
      }
    },
