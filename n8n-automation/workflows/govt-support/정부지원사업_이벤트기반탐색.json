    {
      "id": "ev-node-008",
      "name": "Code 이벤트 프롬프트",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 60],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const f = $input.first().json;\nconst systemPrompt = '당신은 정부지원사업 검색 전문가입니다. 요청한 JSON 형식으로만 응답하세요.';\nconst userPrompt = `회사에서 다음 이벤트가 발생했습니다.\\n\\n이벤트명: ${f['이벤트명'] || ''}\\n이벤트유형: ${f['이벤트유형'] || ''}\\n상세내용: ${f['상세내용'] || ''}\\n\\n이 상황에 적합한 정부지원사업을 찾기 위한 검색 키워드를 5~7개 추출해주세요.\\n\\n반드시 JSON 형식으로만 반환:{\"keywords\": [\"키워드1\", \"키워드2\", \"키워드3\"]}`;\n\nreturn [{ json: {\n  systemPrompt,\n  userPrompt,\n  _eventId: f['Id'] || 0,\n  _eventName: f['이벤트명'] || '',\n  _eventType: f['이벤트유형'] || '',\n  _eventDetail: f['상세내용'] || ''\n} }];"
      }
    },
    {
      "id": "ev-node-009",
      "name": "Gemini 이벤트 분석",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [1680, 60],
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "models/gemini-2.5-flash",
          "mode": "list",
          "cachedResultName": "models/gemini-2.5-flash"
        },
        "messages": {
          "values": [
            {
              "content": "={{ $('Code 이벤트 프롬프트').item.json.systemPrompt }}",
              "role": "model"
            },
            {
              "content": "={{ $('Code 이벤트 프롬프트').item.json.userPrompt }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "credentials": {
        "googlePalmApi": {
