    {
      "id": "ev-node-010",
      "name": "Code 키워드 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 60],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const response = $input.first().json;\nconst promptData = $('Code 이벤트 프롬프트').item.json;\n\nfunction extractText(resp) {\n  if (resp.candidates?.[0]?.content?.parts?.[0]?.text) return resp.candidates[0].content.parts[0].text;\n  if (resp.content?.parts?.[0]?.text) return resp.content.parts[0].text;\n  if (resp.parts?.[0]?.text) return resp.parts[0].text;\n  if (typeof resp.text === 'string') return resp.text;\n  return '';\n}\n\nconst text = extractText(response);\nlet keywords = [];\ntry {\n  const codeBlock = text.match(/```json\\s*([\\s\\S]*?)\\s*```/i);\n  let jsonStr = codeBlock ? codeBlock[1] : '';\n  if (!jsonStr) { const obj = text.match(/\\{[\\s\\S]*\\}/); if (obj) jsonStr = obj[0]; }\n  if (jsonStr) {\n    const parsed = JSON.parse(jsonStr.trim());\n    keywords = parsed.keywords || [];\n  }\n} catch (e) {}\n\nif (keywords.length === 0) {\n  const fallbackMap = {\n    'HR': ['고용지원금', '채용지원', '인력지원', '육아휴직', '출산'],\n    '사업확장': ['온라인마케팅', '디지털전환', '수출지원', '사업화'],\n    '인증': ['인증지원', '인증취득', '기업인증'],\n    '재무': ['자금지원', '융자', '정책자금', '경영안정']\n  };\n  keywords = fallbackMap[promptData._eventType] || [promptData._eventName];\n}\n\nreturn [{ json: {\n  keywords,\n  _eventId: promptData._eventId,\n  _eventName: promptData._eventName,\n  _eventType: promptData._eventType,\n  _eventDetail: promptData._eventDetail\n} }];"
      }
    },
    {
      "id": "ev-node-011",
      "name": "NocoDB 최근공고 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2160, 60],
      "parameters": {
        "method": "GET",
        "url": "https://nocodb.pressco21.com/api/v2/tables/m9pvnifrpmwmbvs/records",
        "sendHeaders": true,
        "headerParameters": {
