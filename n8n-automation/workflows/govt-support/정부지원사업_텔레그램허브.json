    {
      "id": "hub-node-011",
      "name": "Code 검색 결과 포맷",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        -60
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rawItems = $input.all();\nconst cmdData = $('Code 명령어 파싱').first().json;\nconst records = [];\nfor (const raw of rawItems) {\n  if (raw.json.list && Array.isArray(raw.json.list)) {\n    for (const r of raw.json.list) records.push(r);\n  }\n}\n\nif (records.length === 0) {\n  return [{ json: { chatId: cmdData.chatId, telegramText: `🔍 <b>\"${cmdData.args}\"</b> 검색 결과\\n\\n관련 공고를 찾지 못했습니다.` } }];\n}\n\nconst lines = records.map((r, i) => {\n  const link = r['신청Link'] ? ` | <a href=\"${r['신청Link']}\">신청</a>` : '';\n  const deadline = r['마감일'] ? `\\n   마감: ${r['마감일']}` : '';\n  return `${i+1}. <b>${r['지원사업이름']}</b>\\n   ${r['소관기관'] || ''} | ${r['관련도점수']}점${deadline}${link}`;\n}).join('\\n\\n');\n\nconst text = `🔍 <b>\"${cmdData.args}\"</b> 검색 결과 (${records.length}건)\\n\\n${lines}`;\nreturn [{ json: { chatId: cmdData.chatId, telegramText: text } }];"
      }
    },
