    {
      "id": "hub-node-002",
      "name": "Code 명령어 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const msg = $input.first().json.message || $input.first().json;\nconst text = (msg.text || '').trim();\nconst chatId = msg.chat?.id || msg.from?.id || '';\n\n// 보안: 허용된 채팅 ID만 처리 (개발방 메시지 무시)\nconst allowedChatIds = ['7713811206'];\nif (!allowedChatIds.includes(String(chatId))) {\n  return [];\n}\n\nconst parts = text.split(/\\s+/);\nconst rawCmd = (parts[0] || '').toLowerCase();\nconst args = parts.slice(1).join(' ');\n\n// 명령어 정규화\nlet command = 'help';\nif (rawCmd === '/검색' || rawCmd === '/search') command = '/검색';\nelse if (rawCmd === '/요약' || rawCmd === '/summary') command = '/요약';\nelse if (rawCmd === '/이벤트' || rawCmd === '/event') command = '/이벤트';\nelse if (rawCmd === '/상태' || rawCmd === '/status') command = '/상태';\nelse if (rawCmd === '/신청' || rawCmd === '/apply') command = '/신청';\nelse if (rawCmd === '/서류' || rawCmd === '/docs') command = '/서류';\n  else if (rawCmd === '/서식채움' || rawCmd === '/fill') command = '/서식채움';\nelse if (rawCmd.startsWith('/')) command = 'unknown';\n\nreturn [{ json: { command, args, chatId: String(chatId), originalText: text } }];"
      }
    },
