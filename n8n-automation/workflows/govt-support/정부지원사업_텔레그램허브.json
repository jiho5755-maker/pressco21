    {
      "id": "hub-node-021",
      "name": "Code 요약 포맷",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        120
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rawItems = $input.all();\nconst cmdData = $('Code 명령어 파싱').first().json;\nconst records = [];\nfor (const raw of rawItems) {\n  if (raw.json.list && Array.isArray(raw.json.list)) {\n    for (const r of raw.json.list) records.push(r);\n  }\n}\n\nconst total = records.length;\nconst high = records.filter(r => (r['관련도점수'] || 0) >= 70).length;\nconst mid = records.filter(r => { const s = r['관련도점수'] || 0; return s >= 30 && s < 70; }).length;\nconst low = total - high - mid;\n\nconst sourceCount = {};\nrecords.forEach(r => {\n  const src = r['출처'] || '기타';\n  sourceCount[src] = (sourceCount[src] || 0) + 1;\n});\nconst srcText = Object.entries(sourceCount).map(([k, v]) => `${k}:${v}`).join(' | ');\n\nconst today = new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });\nconst text = `📊 <b>${today} 수집 요약</b>\\n\\n총 수집: <b>${total}건</b>\\n\\n🔥 긴급검토(70점↑): ${high}건\\n🧐 검토권장(30~69): ${mid}건\\n⚪ 저관련(30점↓): ${low}건\\n\\n📡 소스: ${srcText || '없음'}`;\n\nreturn [{ json: { chatId: cmdData.chatId, telegramText: text } }];"
      }
    },
