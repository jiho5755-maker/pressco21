    {
      "id": "hub-node-061",
      "name": "Code 서류 현황 포맷",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        820
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rawItems = $input.all();\nconst cmdData = $('Code 명령어 파싱').first().json;\n\nconst records = [];\nfor (const raw of rawItems) {\n  if (raw.json.list && Array.isArray(raw.json.list)) {\n    for (const r of raw.json.list) records.push(r);\n  }\n}\n\nif (records.length === 0) {\n  const text = `📋 <b>서류 작업 현황</b>\\n\\n신청의향 표시된 공고가 없습니다.\\n\\n/신청 {공고ID} 명령어로 신청의향을 표시하면\\n행정서류가 자동 생성됩니다.`;\n  return [{ json: { chatId: cmdData.chatId, telegramText: text } }];\n}\n\nconst statusIcon = {\n  '미시작': '⏳',\n  '초안생성완료': '✅',\n  '검토중': '🔍',\n  '제출완료': '🎉',\n  '포기': '❌'\n};\n\nconst lines = records.map((r, i) => {\n  const status = r['서류_진행상태'] || '미시작';\n  const icon = statusIcon[status] || '⏳';\n  const docLink = r['문서_링크'] ? `\\n   📄 <a href=\"${r['문서_링크']}\">사업계획서 초안 보기</a>` : '';\n  const date = r['문서_생성일시'] ? `\\n   📅 ${String(r['문서_생성일시']).slice(0, 10)}` : '';\n  return `${i+1}. <b>${r['지원사업이름']}</b>\\n   ${r['소관기관'] || ''} | ${icon} ${status}${date}${docLink}`;\n}).join('\\n\\n');\n\nconst text = `📋 <b>서류 작업 현황</b> (${records.length}건)\\n\\n${lines}\\n\\n💡 서류 진행상태: 미시작→초안생성완료→검토중→제출완료`;\nreturn [{ json: { chatId: cmdData.chatId, telegramText: text } }];"
      }
    },
