      "id": "fa003-n07",
      "name": "반려 이메일 발송",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [1300, 200],
      "credentials": {"smtp": {"id": "31jTm9BU7iyj0pVx", "name": "PRESSCO21-SMTP-Naver"}},
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// 이메일 발송 결과 확인 (continueOnFail 활성)\nvar item = $input.item.json || {};\nvar prevData = $('반려사유+이메일 있는가').item.json || {};\nvar errorMessage = '';\n\nif (typeof item.error === 'string' && item.error) {\n  errorMessage = item.error;\n} else if (Array.isArray(item.rejected) && item.rejected.length > 0) {\n  errorMessage = 'Rejected: ' + item.rejected.join(', ');\n}\n\nreturn {\n  json: {\n    nocodb_id: prevData.nocodb_id,\n    name: prevData.name,\n    email: prevData.email,\n    rejectionReason: prevData.rejectionReason,\n    retryCount: Number(prevData.retryCount || 0),\n    emailSuccess: errorMessage === '',\n    errorMessage: errorMessage\n  }\n};",
        "mode": "runOnceForEachItem"
      },
      "id": "fa003-n07b",
      "name": "발송 결과 확인",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1520, 200]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [{"value1": "={{ $json.emailSuccess }}", "value2": true, "operation": "equal"}]
        }
      },
