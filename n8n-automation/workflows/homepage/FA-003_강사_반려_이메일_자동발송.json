      "id": "fa003-n02",
      "name": "NocoDB 반려 미발송 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "jsCode": "var records = $input.first().json.list || [];\nreturn records.map(function(r) {\n  return {\n    json: {\n      nocodb_id: String(r['Id']),\n      name: String(r['성함'] || ''),\n      mobile: String(r['연락처'] || ''),\n      jasamolId: String(r['자사몰 ID'] || ''),\n      email: String(r['이메일 주소'] || ''),\n      status: String(r['진행 상태'] || ''),\n      rejectionReason: String(r['반려 사유'] || ''),\n      retryCount: Number(r['n8n_반려_retry'] || 0)\n    }\n  };\n});",
        "mode": "runOnceForAllItems"
      },
      "id": "fa003-n03",
      "name": "레코드 분리",
      "type": "n8n-nodes-base.code",
