    {
      "parameters": {
        "jsCode": "// 발송 실패: retry 카운트 증가, 3회 이상이면 데드레터\nvar data = $('발송 결과 확인').item.json || {};\nvar newRetry = Number(data.retryCount || 0) + 1;\nvar isDeadLetter = newRetry >= 3;\n\nreturn {\n  json: {\n    nocodb_id: data.nocodb_id,\n    name: data.name,\n    email: data.email,\n    errorMessage: data.errorMessage,\n    newRetry: newRetry,\n    isDeadLetter: isDeadLetter\n  }\n};",
        "mode": "runOnceForEachItem"
      },
