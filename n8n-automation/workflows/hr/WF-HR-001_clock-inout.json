    {
      "parameters": {
        "jsCode": "var parse = $('명령어 파싱').first().json;\nvar resp = $input.first().json;\nvar statusCode = resp.statusCode || 200;\nvar body = resp.body || resp;\nvar resultType = 'edit';\nvar editText = '';\nvar consentKeyboard = '';\n\nif (statusCode === 201 && body.ok) {\n  var now = new Date(Date.now() + 9*3600000);\n  var hh = String(now.getHours()).padStart(2,'0');\n  var mm = String(now.getMinutes()).padStart(2,'0');\n  var modeLabel = { office: '사업장', remote: '재택', field: '외근/촬영' };\n  var mode = modeLabel[parse.workMode] || parse.workMode;\n  if (body.isDeemedHours) {\n    editText = '\\u2705 ' + body.staffName + '님, 업무 시작 보고 접수 (' + hh + ':' + mm + ', ' + mode + ')\\n\\n소정근로시간(8시간)을 근로한 것으로 간주합니다.';\n  } else {\n    editText = '\\u2705 ' + body.staffName + '님, 출근 기록 완료 (' + hh + ':' + mm + ', ' + mode + ')';\n  }\n} else if (statusCode === 403 && body.needsConsent) {\n  resultType = 'consent';\n  editText = '\\ud83d\\udccb 개인정보 수집·이용 동의\\n\\n출퇴근 기록, 업무일지 등 HR 데이터가 근로기준법 제42조에 따라 3년간 보관됩니다.\\n\\n동의하시겠습니까?';\n  consentKeyboard = JSON.stringify({ inline_keyboard: [[{ text: '\\u2705 동의합니다', callback_data: 'hr:consent:yes:' + parse.workMode }, { text: '\\u274c 거부', callback_data: 'hr:consent:no' }]] });\n} else {\n  editText = '\\u274c 오류: ' + (body.error || '알 수 없는 오류');\n}\n\nreturn [{ json: { resultType: resultType, editText: editText, consentKeyboard: consentKeyboard, chatId: parse.chatId, messageId: parse.messageId } }];"
      },
