    {
      "parameters": {
        "jsCode": "var parse = $('명령어 파싱').first().json;\nvar resp = $input.first().json;\nvar statusCode = resp.statusCode || 200;\nvar body = resp.body || resp;\nvar message = '';\nvar hasWorklog = false;\n\nif (statusCode === 201 && body.ok) {\n  var now = new Date(Date.now() + 9*3600000);\n  var hh = String(now.getHours()).padStart(2,'0');\n  var mm = String(now.getMinutes()).padStart(2,'0');\n  if (body.isDeemedHours) {\n    message = '\\u2705 ' + body.staffName + '님, 업무 종료 보고 접수 (' + hh + ':' + mm + ')';\n  } else {\n    message = '\\u2705 ' + body.staffName + '님, 퇴근 기록 완료 (' + hh + ':' + mm + ')';\n  }\n  if (parse.args) {\n    hasWorklog = true;\n  } else {\n    message += '\\n\\n\\ud83d\\udca1 업무일지: /업무 [내용]';\n  }\n} else if (statusCode === 403) {\n  message = '\\ud83d\\udccb 개인정보 동의가 필요합니다.\\n/출근 명령어를 먼저 사용해주세요.';\n} else if (statusCode === 404) {\n  message = '\\u274c 등록되지 않은 사용자입니다. 관리자에게 문의하세요.';\n} else {\n  message = '\\u274c 오류: ' + (body.error || '알 수 없는 오류');\n}\n\nreturn [{ json: { message: message, hasWorklog: hasWorklog, chatId: parse.chatId, telegramUserId: parse.telegramUserId, args: parse.args } }];"
      },
