    {
      "parameters": {
        "jsCode": "var parse = $('명령어 파싱').first().json;\nvar resp = $input.first().json;\nvar body = resp.body || resp;\nvar editText = '';\nvar now = new Date(Date.now() + 9*3600000);\nvar hh = String(now.getHours()).padStart(2,'0');\nvar mm = String(now.getMinutes()).padStart(2,'0');\nvar modeLabel = { office: '사업장', remote: '재택', field: '외근/촬영' };\nvar mode = modeLabel[parse.pendingWorkMode] || parse.pendingWorkMode;\n\nif (body.ok) {\n  if (body.isDeemedHours) {\n    editText = '\\u2705 동의 완료 + 업무 시작 보고 접수 (' + hh + ':' + mm + ', ' + mode + ')\\n\\n소정근로시간(8시간)을 근로한 것으로 간주합니다.';\n  } else {\n    editText = '\\u2705 동의 완료 + 출근 기록 완료 (' + hh + ':' + mm + ', ' + mode + ')';\n  }\n} else {\n  editText = '\\u274c 출근 기록 실패: ' + (body.error || '알 수 없는 오류');\n}\n\nreturn [{ json: { editText: editText, chatId: parse.chatId, messageId: parse.messageId } }];"
