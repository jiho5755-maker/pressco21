    {
      "parameters": {
        "method": "GET",
        "url": "http://foreverlove.co.kr/list/open_api.html",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "mode", "value": "search" },
            { "name": "type", "value": "product" },
            { "name": "display", "value": "Y" },
            { "name": "limit", "value": "={{ $json.query.limit || '20' }}" },
            { "name": "page", "value": "={{ $json.query.page || '1' }}" },
            { "name": "search", "value": "={{ $json.query.search || '' }}" },
            { "name": "category", "value": "={{ $json.query.category || '' }}" },
            { "name": "sort", "value": "={{ $json.query.sort || 'regdt' }}" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Shopkey", "value": "={{ $env.MAKESHOP_SHOPKEY }}" },
            { "name": "Licensekey", "value": "={{ $env.MAKESHOP_LICENSEKEY }}" }
          ]
        },
        "options": {
          "timeout": 30000,
          "response": { "response": { "fullResponse": true } }
        }
      },
      "id": "http-product-list",
      "name": "MakeShop 상품 목록",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "jsCode": "// 메이크샵 상품 목록 응답 파싱\nconst response = $input.first().json;\nlet body = response.body || response;\n\n// Object.values() 필수 (메이크샵 list 응답)\nlet products = [];\nif (body && typeof body === 'object' && !Array.isArray(body)) {\n  products = Object.values(body);\n} else if (Array.isArray(body)) {\n  products = body;\n}\n\nconst items = products.map(p => ({\n  id: p.uid || p.prd_no || '',\n  name: p.prd_name || '',\n  price: parseInt(p.prd_price || '0'),\n  salePrice: parseInt(p.prd_sale_price || p.prd_price || '0'),\n  discount: p.prd_sale_price && p.prd_price ? Math.round((1 - parseInt(p.prd_sale_price) / parseInt(p.prd_price)) * 100) : 0,\n  imageUrl: p.prd_image ? (p.prd_image.startsWith('http') ? p.prd_image : `https://foreverlove.co.kr${p.prd_image}`) : '',\n  category: p.cate_name || '',\n  isSoldOut: p.sto_state_code === '2' || p.prd_soldout === 'Y',\n  isNew: p.prd_new === 'Y',\n  isBest: p.prd_best === 'Y',\n})).filter(p => p.id && p.name);\n\nreturn [{ json: { success: true, data: items, total: items.length } }];"
      },
      "id": "code-parse-list",
      "name": "상품 목록 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "options": {
          "responseCode": 200,
          "responseHeaders": {
            "entries": [
              { "name": "Content-Type", "value": "application/json" },
              { "name": "Access-Control-Allow-Origin", "value": "*" }
            ]
          }
        },
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}"
      },
      "id": "respond-list",
      "name": "상품 목록 응답",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [880, 300]
    },
