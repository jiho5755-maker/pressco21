      "id": "http-categories",
      "name": "MakeShop 카테고리",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 900]
    },
    {
      "parameters": {
        "jsCode": "// 카테고리 파싱\nconst response = $input.first().json;\nlet categories = [];\nif (response && typeof response === 'object') {\n  const vals = Array.isArray(response) ? response : Object.values(response);\n  categories = vals.map(c => ({\n    id: c.cate_no || c.id || '',\n    name: c.cate_name || c.name || '',\n    parentId: c.parent_cate_no || '',\n    depth: parseInt(c.depth || '1'),\n  })).filter(c => c.id && c.name);\n}\nreturn [{ json: { success: true, data: categories } }];"
      },
      "id": "code-parse-categories",
      "name": "카테고리 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 900]
    },
