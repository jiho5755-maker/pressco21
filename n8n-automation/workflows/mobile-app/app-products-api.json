      "id": "http-product-detail",
      "name": "MakeShop 상품 상세",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 600]
    },
    {
      "parameters": {
        "jsCode": "// 메이크샵 상품 상세 응답 파싱\nconst response = $input.first().json;\nlet body = response.body || response;\nlet products = [];\nif (body && typeof body === 'object' && !Array.isArray(body)) {\n  products = Object.values(body);\n}\nconst p = products[0] || {};\n\nconst detail = {\n  id: p.uid || p.prd_no || '',\n  name: p.prd_name || '',\n  price: parseInt(p.prd_price || '0'),\n  salePrice: parseInt(p.prd_sale_price || p.prd_price || '0'),\n  discount: p.prd_sale_price && p.prd_price ? Math.round((1 - parseInt(p.prd_sale_price) / parseInt(p.prd_price)) * 100) : 0,\n  imageUrl: p.prd_image ? (p.prd_image.startsWith('http') ? p.prd_image : `https://foreverlove.co.kr${p.prd_image}`) : '',\n  images: [p.prd_image, p.prd_image2, p.prd_image3, p.prd_image4].filter(Boolean).map(img => img.startsWith('http') ? img : `https://foreverlove.co.kr${img}`),\n  description: p.prd_detail || '',\n  category: p.cate_name || '',\n  isSoldOut: p.sto_state_code === '2' || p.prd_soldout === 'Y',\n  options: p.prd_option_name ? p.prd_option_name.split('|').map(o => o.trim()) : [],\n};\n\nreturn [{ json: { success: true, data: detail } }];"
      },
      "id": "code-parse-detail",
      "name": "상품 상세 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 600]
    },
    {
      "parameters": {
        "options": {
          "responseCode": 200,
          "responseHeaders": {
            "entries": [
              { "name": "Content-Type", "value": "application/json" },
