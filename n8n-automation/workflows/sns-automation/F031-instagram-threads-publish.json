    {
      "parameters": {
        "jsCode": "// 발행 결과 정리\nconst igPublish = $('IG 게시물 발행').first().json;\nconst threadsPublish = $input.first().json;\nconst input = $('입력값 검증').first().json;\n\nconst igSuccess = igPublish.id && !igPublish.error;\nconst threadsSuccess = threadsPublish.id && !threadsPublish.error;\n\nconst igStatus = igSuccess ? '✅ 발행 완료' : '❌ 실패: ' + (igPublish.error?.message || 'unknown');\nconst threadsStatus = threadsSuccess ? '✅ 발행 완료' : '❌ 실패: ' + (threadsPublish.error?.message || 'unknown');\n\nconst msg = `📢 *SNS 동시 발행 결과*\\n\\n` +\n  `📸 Instagram: $\\{igStatus}\\n` +\n  `🧵 Threads: $\\{threadsStatus}\\n\\n` +\n  `📝 $\\{input.caption?.substring(0, 80)}...`;\n\nreturn [{ json: {\n  message: msg,\n  igId: igPublish.id || null,\n  threadsId: threadsPublish.id || null,\n  success: igSuccess || threadsSuccess\n}}];"
      },
      "id": "f031-0001-0001-4000-8000-000000000009",
      "name": "결과 정리",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
