    {
      "parameters": {
        "jsCode": "// 입력값 검증 및 정리\nconst body = $input.first().json.body || $input.first().json;\n\nconst imageUrl = body.imageUrl || body.image_url || '';\nconst caption = body.caption || '';\nconst hashtags = body.hashtags || '#프레스코21 #꽃공예 #압화 #핸드메이드';\nconst postToThreads = body.threads !== false; // 기본: Threads도 발행\nconst mediaType = body.mediaType || 'IMAGE'; // IMAGE, VIDEO, CAROUSEL_ALBUM\n\n// 캡션 + 해시태그 결합\nconst fullCaption = caption + (hashtags ? '\\n\\n' + hashtags : '');\n\n// Threads용 텍스트 (짧은 버전)\nconst threadsText = caption.length > 300 \n  ? caption.substring(0, 297) + '...' \n  : caption;\n\nif (!imageUrl && mediaType !== 'TEXT') {\n  return [{ json: { \n    error: true, \n    message: 'imageUrl이 필요합니다. MinIO 공개 URL을 사용하세요.' \n  }}];\n}\n\nreturn [{ json: {\n  error: false,\n  imageUrl,\n  caption: fullCaption,\n  threadsText,\n  threadsImageUrl: imageUrl,\n  postToThreads,\n  mediaType,\n  igAccountId: '', // 환경변수에서 가져옴\n  timestamp: new Date().toISOString()\n}}];"
      },
      "id": "f031-0001-0001-4000-8000-000000000002",
      "name": "입력값 검증",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, 300]
    },
