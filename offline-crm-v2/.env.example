# ─────────────────────────────────────────────────
# PRESSCO21 Offline CRM v2 — 환경변수 예시
# 이 파일을 .env.local로 복사 후 실제 값을 채워 넣으세요.
# .env.local은 gitignore에 포함되어 있으므로 절대 커밋되지 않습니다.
# ─────────────────────────────────────────────────

# n8n Webhook 프록시 URL (Vite dev proxy 경유)
VITE_N8N_WEBHOOK_URL=/crm-proxy

# CRM 대금 납부 리마인더 Webhook URL (Vite dev proxy 경유)
VITE_CRM_PAYMENT_REMINDER_WEBHOOK_URL=/crm-payment-reminder

# 바로빌 세금계산서 Webhook URL (테스트환경 전용, Vite/Nginx same-origin proxy 경유)
VITE_BAROBILL_TAX_INVOICE_ISSUE_WEBHOOK_URL=/webhook/crm/barobill/tax-invoices/issue
VITE_BAROBILL_TAX_INVOICE_STATUS_WEBHOOK_URL=/webhook/crm/barobill/tax-invoices/sync-status
VITE_BAROBILL_TAX_INVOICE_CANCEL_WEBHOOK_URL=/webhook/crm/barobill/tax-invoices/cancel
VITE_BAROBILL_TAX_INVOICE_MODE=test
VITE_BAROBILL_ALLOW_PRODUCTION_ISSUE=false

# CRM 전용 API Key (n8n WF-CRM-PROXY에서 검증하는 키)
VITE_CRM_API_KEY=your_crm_api_key_here

# NocoDB 직접 접근 토큰 (Python 마이그레이션 스크립트 전용)
# 스크립트 실행 방법: export NOCODB_TOKEN=$(grep NOCODB_TOKEN .env.local | cut -d= -f2)
NOCODB_TOKEN=your_nocodb_token_here
