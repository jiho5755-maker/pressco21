  "description": "PRESSCO21 authoritative cost-profile master template. Use this as the single source of truth for verified product cost rules.",
  "baseProfiles": {
    "china_import_simple": {
      "label": "중국 사입 기본형",
      "procurementType": "china_import",
      "fixedDefaults": {
        "branchManagementRate": 0.1,
        "oceanFreightRatePerCbmKrw": 82000,
        "warehouseHandlingRatePerCbmKrw": 6000,
        "customsBrokerFeePerShipmentKrw": 33000,
        "originCertificateFeeCny": 250,
        "domesticInboundShippingPerUnit": 150,
        "vatRate": 0.1,
        "lossRate": 0.03,
        "inspectionCost": 0,
        "packagingCost": 0,
        "freightPerUnit": 0,
        "tariffRate": 0,
        "includeVatInCogs": false
      },
      "variableInputs": [
        "purchaseCny",
        "exchangeRate",
        "allocationQuantity",
        "unitVolumeCbm",
        "packageLengthCm",
        "packageWidthCm",
        "packageHeightCm",
        "originCertificateApplied"
      ],
      "formula": "purchaseCny * exchangeRate + branchManagement + internationalFreightByCbm + customsBrokerAllocated + originCertificateAllocated + domesticInboundShippingPerUnit + tariff + packagingCost + inspectionCost + lossReserve"
    },
    "domestic_purchase_simple": {
      "label": "국내 사입 기본형",
      "procurementType": "domestic_purchase",
      "fixedDefaults": {
        "vatRate": 0.1,
        "lossRate": 0.02,
        "inspectionCost": 0,
        "packagingCost": 0,
        "shippingPerUnit": 150,
        "includeVatInCogs": false
      },
      "variableInputs": [
        "purchaseKrw"
      ],
      "formula": "purchaseKrw + shippingPerUnit + packagingCost + inspectionCost + lossReserve"
    },
    "domestic_manufacturing_simple": {
      "label": "국내 직제조 기본형",
      "procurementType": "domestic_manufacturing",
      "fixedDefaults": {
        "hourlyLaborCost": 15000,
        "monthlyOverheadPerUnit": 0,
        "packagingCost": 0,
        "inspectionCost": 0,
        "lossRate": 0.03,
        "includeVatInCogs": false
      },
      "variableInputs": [
        "materialCost",
        "laborMinutes"
      ],
      "formula": "materialCost + laborMinutes/60*hourlyLaborCost + monthlyOverheadPerUnit + packagingCost + inspectionCost + lossReserve"
    }
  },
