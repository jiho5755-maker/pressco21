    {
      "parameters": {
        "jsCode": "// ===================================================\n// Router fallback: 지원하지 않는 action\n// ===================================================\n\nconst action = String($input.first().json._action || '').trim();\n\nreturn [{\n  json: {\n    success: false,\n    _status: 400,\n    error: {\n      code: 'INVALID_ACTION',\n      message: action ? `알 수 없는 요청입니다: ${action}` : '지원하지 않는 action입니다.'\n    },\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
