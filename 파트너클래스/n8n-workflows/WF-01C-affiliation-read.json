    {
      "parameters": {
        "jsCode": "// ===================================================\n// WF-01-D: getAffiliations - 협회 목록 응답\n// ===================================================\n\nconst response = $input.first().json;\nconst affiliList = response.list || [];\n\nconst affiliations = affiliList.map(a => ({\n  affiliation_code: a.affiliation_code || '',\n  name: a.name || '',\n  logo_url: a.logo_url || '',\n  discount_rate: Number(a.discount_rate) || 0,\n  incentive_tiers: [\n    { target: Number(a.target_1) || 5000000, incentive: Number(a.incentive_1) || 250000 },\n    { target: Number(a.target_2) || 10000000, incentive: Number(a.incentive_2) || 500000 },\n    { target: Number(a.target_3) || 20000000, incentive: Number(a.incentive_3) || 1200000 }\n  ],\n  contact_name: a.contact_name || '',\n  memo: a.memo || ''\n}));\n\nreturn [{\n  json: {\n    success: true,\n    data: affiliations,\n    total: affiliations.length,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
