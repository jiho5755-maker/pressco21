    {
      "parameters": {
        "jsCode": "// ===================================================\n// getPartnerApplicationStatus 처리\n// member_id로 파트너 여부 -> 신청 이력 조회\n// ===================================================\n\nconst query = $input.first().json.query;\nconst memberId = (query.member_id || '').trim();\n\nif (!memberId) {\n  return [{\n    json: {\n      _done: true,\n      success: false,\n      error: { code: 'NOT_LOGGED_IN', message: '로그인이 필요합니다.' },\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    memberId,\n    _done: false\n  }\n}];"
      },
