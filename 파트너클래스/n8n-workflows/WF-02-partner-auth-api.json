      "parameters": {
        "jsCode": "// ===================================================\n// getPartnerAuth 파라미터 검증\n// ===================================================\n\nconst query = $input.first().json.query;\nconst memberId = (query.member_id || '').trim();\n\nif (!memberId) {\n  return [{\n    json: {\n      _error: true,\n      success: false,\n      error: { code: 'NOT_LOGGED_IN', message: '로그인이 필요합니다.' },\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    memberId,\n    _error: false\n  }\n}];"
      },
