    {
      "parameters": {
        "jsCode": "// ===================================================\n// getPartnerAuth 응답 구성\n// 파트너 존재 -> 파트너 정보 반환\n// 파트너 미존재 -> tbl_Applications 조회하여 상태 분기\n// ===================================================\n\nconst partnerResponse = $input.first().json;\nconst partnerList = partnerResponse.list || [];\nconst memberId = $('Parse Auth Params').first().json.memberId;\n\nif (partnerList.length > 0) {\n  const p = partnerList[0];\n\n  // 파트너 정보 반환 (pending/inactive 포함, 프론트에서 상태별 안내)\n  return [{\n    json: {\n      _needAppCheck: false,\n      success: true,\n      data: {\n        is_partner: true,\n        member_id: memberId,\n        partner_code: p.partner_code || '',\n        partner_name: p.partner_name || '',\n        grade: p.grade || 'SILVER',\n        commission_rate: Number(p.commission_rate) || 0,\n        reserve_rate: Number(p.reserve_rate) || 0,\n        education_completed: p.education_completed === true || p.education_completed === 'true',\n        status: p.status || 'active'\n      },\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\n// 파트너 미존재 -> 신청 테이블 확인 필요\nreturn [{\n  json: {\n    _needAppCheck: true,\n    memberId\n  }\n}];"
      },
