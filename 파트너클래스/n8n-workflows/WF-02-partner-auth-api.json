    {
      "parameters": {
        "jsCode": "// ===================================================\n// 파트너 미등록 + 신청 상태 응답 구성\n// ===================================================\n\nconst appResponse = $input.first().json;\nconst appList = appResponse.list || [];\nconst memberId = $('Check Partner Exists').first().json.memberId;\n\nif (appList.length > 0) {\n  const app = appList[0];\n  return [{\n    json: {\n      success: true,\n      data: {\n        is_partner: false,\n        member_id: memberId,\n        status: 'pending',\n        application_status: app.status || 'PENDING',\n        applied_date: app.applied_date || ''\n      },\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\n// 신청 이력도 없음\nreturn [{\n  json: {\n    success: true,\n    data: {\n      is_partner: false,\n      member_id: memberId,\n      status: 'not_partner'\n    },\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
