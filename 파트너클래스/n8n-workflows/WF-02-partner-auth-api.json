    {
      "parameters": {
        "jsCode": "// ===================================================\n// 교육 이수 상태 응답 구성\n// ===================================================\n\nconst response = $input.first().json;\nconst partnerList = response.list || [];\nconst memberId = $('Parse Education Params').first().json.memberId;\n\nif (partnerList.length === 0) {\n  // 파트너 아닌 경우 (에러 아닌 정상 응답)\n  return [{\n    json: {\n      success: true,\n      data: {\n        is_partner: false,\n        member_id: memberId\n      },\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\nconst p = partnerList[0];\n\n// education_completed 정규화\nlet eduCompleted = 'N';\nif (p.education_completed === true || p.education_completed === 'true' || p.education_completed === 'TRUE' || p.education_completed === 'Y') {\n  eduCompleted = 'Y';\n}\n\n// education_score 숫자 변환\nlet eduScore = null;\nif (p.education_score !== undefined && p.education_score !== null && p.education_score !== '') {\n  const parsed = Number(p.education_score);\n  if (!isNaN(parsed)) eduScore = parsed;\n}\n\nreturn [{\n  json: {\n    success: true,\n    data: {\n      is_partner: true,\n      partner_code: p.partner_code || '',\n      education_completed: eduCompleted,\n      education_date: p.education_date ? String(p.education_date) : null,\n      education_score: eduScore\n    },\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
