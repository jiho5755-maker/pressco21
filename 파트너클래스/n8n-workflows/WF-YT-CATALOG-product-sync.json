    {
      "id": "wytc-10",
      "name": "Upsert Decision",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2380, 300],
      "parameters": {
        "jsCode": "var parsed = $('Parse All Products').first().json;\nvar existingResp = $input.first().json;\nvar newProducts = parsed.products || [];\nvar existing = (existingResp && existingResp.list) ? existingResp.list : [];\nvar existingMap = {};\nfor (var i = 0; i < existing.length; i++) {\n  existingMap[String(existing[i].branduid)] = { id: existing[i].Id, price: existing[i].price };\n}\nvar toInsert = [];\nvar toUpdate = [];\nfor (var j = 0; j < newProducts.length; j++) {\n  var p = newProducts[j];\n  var ex = existingMap[String(p.branduid)];\n  if (ex) {\n    if (String(ex.price) !== String(p.price)) {\n      toUpdate.push({ Id: ex.id, price: p.price, synced_at: p.synced_at });\n    }\n  } else {\n    toInsert.push(p);\n  }\n}\nreturn [{ json: { toInsert: toInsert, toUpdate: toUpdate, insertCount: toInsert.length, updateCount: toUpdate.length, totalProcessed: newProducts.length } }];"
      }
    },
