    {
      "id": "wytc-08",
      "name": "Parse All Products",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1900, 300],
      "parameters": {
        "jsCode": "// 메이크샵 전체 상품 카탈로그 파싱 (6페이지 순차 집계)\n// 올바른 엔드포인트: /list/open_api.html?type=product&page=N\n// 올바른 응답 키: list[] (datas 아님), uid (branduid 아님)\nvar CATEGORY_KEYWORDS = {\n  '압화': ['압화','프레스드플라워','프레스드','건조꽃','드라이플라워','하바리움','부케','꽃다발','꽃'],\n  '레진': ['레진','UV레진','에폭시','실리콘몰드','몰드','레지너스','꽃레진'],\n  '캔들': ['캔들','왁스','소이왁스','향초','심지'],\n  '석고': ['석고','방향제','아로마'],\n  '비즈': ['비즈','구슬','클레이']\n};\nfunction detectCategory(name) {\n  if (!name) return '';\n  for (var cat in CATEGORY_KEYWORDS) {\n    var ws = CATEGORY_KEYWORDS[cat];\n    for (var i = 0; i < ws.length; i++) {\n      if (name.indexOf(ws[i]) >= 0) return cat;\n    }\n  }\n  return '';\n}\nfunction extractKeywords(name) {\n  if (!name) return [];\n  var kws = [];\n  for (var cat in CATEGORY_KEYWORDS) {\n    var ws = CATEGORY_KEYWORDS[cat];\n    for (var i = 0; i < ws.length; i++) {\n      if (name.indexOf(ws[i]) >= 0 && kws.indexOf(ws[i]) < 0) kws.push(ws[i]);\n    }\n  }\n  return kws;\n}\nfunction parsePage(item) {\n  try {\n    var raw = item.json;\n    var body = typeof raw === 'string' ? raw : (raw.data || raw.body || JSON.stringify(raw));\n    if (typeof body === 'object') body = JSON.stringify(body);\n    var d = JSON.parse(body);\n    if (!d || d.return_code !== '0000') return [];\n    return Array.isArray(d.list) ? d.list : [];\n  } catch(e) { return []; }\n}\nvar allRaw = [];\ntry { allRaw = allRaw.concat(parsePage($('Fetch Page 1').first())); } catch(e) {}\ntry { allRaw = allRaw.concat(parsePage($('Fetch Page 2').first())); } catch(e) {}\ntry { allRaw = allRaw.concat(parsePage($('Fetch Page 3').first())); } catch(e) {}\ntry { allRaw = allRaw.concat(parsePage($('Fetch Page 4').first())); } catch(e) {}\ntry { allRaw = allRaw.concat(parsePage($('Fetch Page 5').first())); } catch(e) {}\ntry { allRaw = allRaw.concat(parsePage($('Fetch Page 6').first())); } catch(e) {}\nvar records = [];\nvar now = new Date().toISOString();\nfor (var j = 0; j < allRaw.length; j++) {\n  var p = allRaw[j];\n  if (p.sell_accept !== 'Y' || p.display !== 'Y') continue;\n  var uid = String(p.uid || '');\n  var name = p.product_name || '';\n  if (!uid || !name) continue;\n  var price = parseInt(p.sellprice) || 0;\n  var image = '';\n  if (p.multi_image && typeof p.multi_image === 'string' && p.multi_image.trim()) {\n    image = p.multi_image.split(',')[0].trim();\n    if (image && !image.startsWith('http')) image = 'https://foreverlove.co.kr' + image;\n  }\n  records.push({\n    branduid: uid,\n    product_name: name,\n    price: price,\n    image_url: image,\n    product_url: 'https://foreverlove.co.kr/shop/shopdetail.html?branduid=' + uid,\n    category_name: detectCategory(name),\n    keywords: JSON.stringify(extractKeywords(name)),\n    status: 'active',\n    synced_at: now\n  });\n}\nif (records.length === 0) {\n  throw new Error('활성 상품이 없습니다. API 응답 확인 필요 (endpoint: /list/open_api.html)');\n}\nreturn [{ json: { products: records, total: records.length } }];"
      }
    },
