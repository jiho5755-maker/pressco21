      "parameters": {
        "jsCode": "var d = $('Upsert Decision').first().json;\nvar now = new Date().toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' });\nvar msg = '\uD83D\uDCE6 메이크샵 상품 카탈로그 동기화 완료\\n처리: ' + (d.totalProcessed||0) + '개\\n신규: ' + (d.insertCount||0) + '개\\n가격갱신: ' + (d.updateCount||0) + '개\\n시간: ' + now;\nreturn [{ json: { message: msg, insertCount: d.insertCount, updateCount: d.updateCount, totalProcessed: d.totalProcessed } }];"
      }
    },
